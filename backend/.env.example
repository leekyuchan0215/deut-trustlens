APP_ENV=development
USE_MOCK=true

DATABASE_URL=postgresql+psycopg://trustlens:trustlens@localhost:5432/trustlens

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
CLAUDE_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_CLAUDE_MODEL=
OPENROUTER_GEMINI_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=

TAVILY_API_KEY=

JUDGE_PROVIDER=
JUDGE_MODEL=

FRONTEND_ORIGIN=http://localhost:3000

PROVIDER_TIMEOUT_SECONDS=45
PROVIDER_MAX_RETRIES=2
ANSWER_MAX_TOKENS=1000
TAVILY_MAX_RESULTS_PER_QUERY=5
EMBEDDING_BATCH_SIZE=64
CHUNK_MAX_CHARS=1200

# Presentation demo: shorter claim/evidence path (set false for full analysis)
PIPELINE_FAST_MODE=false
FAST_MODE_MAX_CLAIMS=8
FAST_MODE_MAX_WEB_CLAIMS=4
FAST_MODE_TAVILY_MAX_QUERIES=4
FAST_MODE_HYBRID_TOP_K=3

# Trust Score weights (합=1.0) — 합의·논리 비중 ↑, 근거·출처 비중 ↓
TRUST_WEIGHT_EVIDENCE=0.28
TRUST_WEIGHT_SOURCE=0.12
TRUST_WEIGHT_CONSENSUS=0.28
TRUST_WEIGHT_LOGIC=0.22
TRUST_WEIGHT_FRESHNESS=0.10

TRUST_SCORE_GENEROUS_MODE=false
